<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= member.name %> - Бригада №5</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <div class="header-container">
            <a href="/" class="nav_logo">Помпі</a>
            <nav class="header-menu">
                <ul>
                    <li><a class="menu" href="/">На Головну</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main style="padding-top: 40px; display: flex; flex-direction: column; align-items: center;">
        <div class="form_container" style="max-width: 600px; transform: scale(1); width: 100%;">
            <h1 style="text-align: center; color: var(--color-brand-dark); margin-bottom: 20px;">
                <%= member.name %>
            </h1>
            
            <div style="text-align: center; margin-bottom: 20px;">
                <img src="<%= member.photo %>" alt="<%= member.name %>" 
                     style="width: 200px; height: 200px; object-fit: cover; border-radius: 50%; border: 4px solid var(--color-brand-light);">
            </div>

            <ul style="list-style: none; padding: 0;">
                <li style="padding: 10px; border-bottom: 1px solid #eee;">
                    <strong><i class="fas fa-user-tag"></i> Роль:</strong> <%= member.role %>
                </li>
                <li style="padding: 10px; border-bottom: 1px solid #eee;">
                    <strong><i class="fas fa-birthday-cake"></i> Вік:</strong> <%= member.age %> років
                </li>
                <li style="padding: 10px;">
                    <strong><i class="fas fa-gamepad"></i> Хобі:</strong> <%= member.hobby %>
                </li>
            </ul>
        </div>
    </main>

    <footer>
        <div class="footer-container">
            <div class="footer-bottom">
                <p>© 2026 Бригада №5. Всі права захищені.</p>
            </div>
        </div>
    </footer>
</body>
</html>